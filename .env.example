# Copy this to .env and fill in your values
# NEVER commit .env to git

# Database
DATABASE_URL=postgresql://ukfont:changeme@db:5432/ukfont
DB_PASSWORD=changeme

# Google Fonts API (get from console.cloud.google.com)
GOOGLE_FONTS_API_KEY=your_google_fonts_api_key_here

# Anthropic (for Claude Vision font-from-image)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Session secret (generate a random string)
SESSION_SECRET=generate-a-random-64-char-string-here

# Port (Coolify sets this automatically)
PORT=5000
